<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Stm32UIController.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Stm32UIController.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Stm32UIController">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

<Grid ColumnDefinitions="180,*">
    <StackPanel Grid.Column="0"
                Spacing="10"
                Margin="10">
        
        <Button Content="Температура"
                Command="{Binding OpenTemperatureCommand}"/>

        <Button Content="График температуры"
                Command="{Binding OpenTemperatureGraphCommand}"/>

        <Button Content="График влажности"
                Command="{Binding OpenHumidityGraphCommand}"/>

    </StackPanel>
    <StackPanel Grid.Column="1" Spacing="10" Margin="10">
        <ContentControl Content="{Binding CurrentView}"/>
        
    </StackPanel>

    <ContentControl
        x:Name="ContentHost"
        Grid.Column="1"/>

</Grid>

</Window>
